-- Clean & Load bronze.crm_cust_info table
SELECT * FROM bronze.crm_cust_info;

-- 1) Data Quality Check One:-
	-- Check if cst_id is unique or not and if it is having any NULL values
	SELECT cst_id, COUNT(*)
	FROM bronze.crm_cust_info
	GROUP BY cst_id
	HAVING COUNT(*) > 1 OR cst_id IS NULL;

	-- Solve this duplicate issue in cst_id column:
		-- Add another column "flag_last" to rank the lastest data of cst_id according to cst_create_date in descending order
		SELECT *, ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) AS flag_last
		FROM bronze.crm_cust_info
		WHERE cst_id = 29466;

		-- See whole data where "flag_last" is anything but 1 (means all non latest data, because latest data for each cst_id is ranked 1)
		SELECT * FROM (
			SELECT *, ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) AS flag_last
			FROM bronze.crm_cust_info
		)
		t WHERE flag_last != 1;

		-- See whole data where "flag_last" is 1 (means all latest data, because latest data for each cst_id is ranked 1)
		SELECT * FROM (
			SELECT *, ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) AS flag_last
			FROM bronze.crm_cust_info
		)
		t WHERE flag_last = 1;

-- 2) Data Quality Check Two:-
	-- Check for Unwanted Spaces in cst_firstname Column
	SELECT cst_firstname FROM bronze.crm_cust_info
	WHERE cst_firstname != TRIM(cst_firstname);

	-- Check for Unwanted Spaces in cst_lastname Column
	SELECT cst_lastname FROM bronze.crm_cust_info
	WHERE cst_lastname != TRIM(cst_lastname);

	-- Check for Unwanted Spaces in cst_gndr Column
	SELECT cst_gndr FROM bronze.crm_cust_info
	WHERE cst_gndr != TRIM(cst_gndr);

	-- Solve this problem of unwanted spaces
		--Triming the extra spaces from the columns where we found extra spaces but only where flag_last=1 (as flag_last=1 is our latest record)
		SELECT
		cst_id,
		cst_key,
		TRIM(cst_firstname) AS cst_firstname,
		TRIM(cst_lastname) AS cst_lastname,
		cst_material_status,
		cst_gndr,
		cst_create_date
		FROM (
			SELECT *, ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) AS flag_last
			FROM bronze.crm_cust_info
		)
		t WHERE flag_last = 1;

-- 3) Data Quality Check Three:-
	-- Check Data Standarization & Consistency in cst_gndr Column
	SELECT DISTINCT cst_gndr FROM bronze.crm_cust_info;
	
	-- Check Data Standarization & Consistency in cst_material_status Column
	SELECT DISTINCT cst_material_status FROM bronze.crm_cust_info;

	--Solve this Standarization & Consistency
		-- Standarize the data of cst_gndr column with F as "Female" and M as "Male" and cst_material_status column with S as "Single" and M as "Married" and NULL values as "n/a" and remove unwanted spaces but only where flag_last=1 (as flag_last=1 is our latest record)
		SELECT
		cst_id,
		cst_key,
		TRIM(cst_firstname) AS cst_firstname,
		TRIM(cst_lastname) AS cst_lastname,
		CASE WHEN UPPER(TRIM(cst_material_status)) = 'S' THEN 'Single'
			WHEN UPPER(TRIM(cst_material_status)) = 'M' THEN 'Married'
			ELSE 'n/a'
		END cst_material_status,
		CASE WHEN UPPER(TRIM(cst_gndr)) = 'F' THEN 'Female'
			WHEN UPPER(TRIM(cst_gndr)) = 'M' THEN 'Male'
			ELSE 'n/a'
		END cst_gndr,
		cst_create_date
		FROM (
			SELECT *, ROW_NUMBER() OVER (PARTITION BY cst_id ORDER BY cst_create_date DESC) AS flag_last
			FROM bronze.crm_cust_info
		)
		t WHERE flag_last = 1;
